FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
WORKDIR /app
EXPOSE 5001
ENV ASPNETCORE_URLS=http://+:5001

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY ["src/CatalogoEventos.API/CatalogoEventos.API.csproj", "src/CatalogoEventos.API/"]
RUN dotnet restore "src/CatalogoEventos.API/CatalogoEventos.API.csproj"
COPY . .
WORKDIR "/src/src/CatalogoEventos.API"
RUN dotnet build "CatalogoEventos.API.csproj" -c Release -o /app/build

FROM build AS publish
RUN dotnet publish "CatalogoEventos.API.csproj" -c Release -o /app/publish

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "CatalogoEventos.API.dll"]
